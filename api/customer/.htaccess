<IfModule mod_headers.c>
    # Match your exact Angular origin port
    SetEnvIf Origin "http://localhost:64700" AccessControlAllowOrigin=$0
    Header set Access-Control-Allow-Origin %{AccessControlAllowOrigin}e env=AccessControlAllowOrigin
    Header set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, Accept"
    Header set Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE"
    Header set Access-Control-Max-Age "86400"

    # If it's an OPTIONS preflight request, respond immediately with 200 OK and stop processing
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ - [R=200,L]
</IfModule>

# Standard CodeIgniter 4 Routing Rules below...
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /24X7customeradmin/
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    
    # If the requested filename exists as a real file or folder, serve it directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Otherwise, forward everything to index.php
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>